<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="cramped_environment">
    <!-- ROS 2 State Plugin -->
    <plugin name="gazebo_ros_state" filename="libgazebo_ros_state.so">
      <ros>
        <namespace>/gazebo</namespace>
      </ros>
    </plugin>

    <!-- A global light source -->
    <include>
      <uri>model://sun</uri>
    </include>
    <!-- A ground plane -->
    <include>
      <uri>model://ground_plane</uri>
    </include>

    <!-- Obstacles representing the PCD Map -->
    <model name="obs_0">
      <static>true</static>
      <pose>-3.20 7.20 1.60 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>0.80 0.80 0.80</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <transparency>0.5</transparency>
          <geometry>
            <box>
              <size>0.80 0.80 0.80</size>
            </box>
          </geometry>
          <material>
            <script>
              <name>Gazebo/Grey</name>
              <uri>file://media/materials/scripts/gazebo.material</uri>
            </script>
          </material>
        </visual>
      </link>
    </model>
